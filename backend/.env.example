# Copy this file to ".env" (same folder) and fill in your real values.
# NEVER commit your real .env file to GitHub.

# The port your backend will run on (3000 is fine for local dev)
PORT=3000

# The Gmail address that will SEND the email (your own Gmail)
SENDER_EMAIL=your_email@gmail.com

# A Google "App Password" (NOT your normal Gmail password).
# How to get one:
#   1. Go to https://myaccount.google.com/security
#   2. Turn on 2-Step Verification (required)
#   3. Visit https://myaccount.google.com/apppasswords
#   4. Create a new app password (pick "Mail" / "Other")
#   5. Google gives you a 16-character code — paste it below (no spaces)
SENDER_APP_PASSWORD=your16charapppassword

# The email address that will RECEIVE the contact form messages (you)
RECEIVER_EMAIL=your_email@gmail.com
